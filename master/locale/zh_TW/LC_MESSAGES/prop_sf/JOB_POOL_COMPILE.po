#: ../../../prop_sf/JOB_POOL_COMPILE.rst:2
msgid "JOB_POOL_COMPILE"
msgstr ""

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:6
msgid "Ninja only: Pool used for compiling."
msgstr "僅 Ninja：用於編譯的池。"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:8
msgid ""
"The number of parallel compile processes could be limited by defining pools "
"with the global :prop_gbl:`JOB_POOLS` property and then specifying here the "
"pool name."
msgstr ""
"可以透過使用全域 :prop_gbl:`JOB_POOLS` 屬性定義池，然後在此處指定池名稱來限制"
"並行編譯行程的數量。"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:12
msgid ""
"This allows to override the :prop_tgt:`JOB_POOL_COMPILE` value for specific "
"source files within a same target."
msgstr "這允許為同一目標內的特定來源檔案覆寫 :prop_tgt:`JOB_POOL_COMPILE` 值。"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:15
msgid "For instance:"
msgstr "例如："

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:17
msgid "set_property(SOURCE main.cc PROPERTY JOB_POOL_COMPILE two_jobs)"
msgstr ""

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:21
msgid "This property is undefined by default."
msgstr "此屬性預設為未定義。"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:24
msgid "See Also"
msgstr "另請參見"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:26
msgid ":prop_fs:`JOB_POOL_COMPILE` file set property"
msgstr ":prop_fs:`JOB_POOL_COMPILE` 檔案集屬性"

#: ../../../prop_sf/JOB_POOL_COMPILE.rst:27
msgid ":prop_tgt:`JOB_POOL_COMPILE` target property"
msgstr ":prop_tgt:`JOB_POOL_COMPILE` 目標屬性"
