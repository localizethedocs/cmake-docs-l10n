#: ../../../release/4.3.rst:2
msgid "CMake 4.3 Release Notes"
msgstr ""

#: ../../../release/4.3.rst:5
msgid "Contents"
msgstr ""

#: ../../../release/4.3.rst:8
msgid "Changes made since CMake 4.2 include the following."
msgstr ""

#: ../../../release/4.3.rst:11
msgid "New Features"
msgstr ""

#: ../../../release/4.3.rst:14
msgid "Instrumentation"
msgstr ""

#: ../../../release/4.3.rst:16
msgid ""
":manual:`cmake-instrumentation(7)` was added to enable collection of timing "
"data, target information, and system diagnostic information during the "
"configure, generate, build, test, and install steps of a CMake project:"
msgstr ""

#: ../../../release/4.3.rst:20
msgid ""
"Instrumentation data are :ref:`indexed <cmake-instrumentation Indexing>` and "
"provided to :ref:`callbacks <cmake-instrumentation Callbacks>` for custom "
"processing."
msgstr ""

#: ../../../release/4.3.rst:24
msgid "Instrumentation data are included in submissions to CDash."
msgstr ""

#: ../../../release/4.3.rst:26
msgid ""
"Optionally, :ref:`Google Trace Event Format <cmake-instrumentation Google "
"Trace File>` files may be generated to visualize instrumentation data."
msgstr ""

#: ../../../release/4.3.rst:31
msgid "File-Based API"
msgstr ""

#: ../../../release/4.3.rst:33
msgid ""
"The :manual:`cmake-file-api(7)` \"codemodel\" version 2 version field has "
"been updated to 2.10."
msgstr ""

#: ../../../release/4.3.rst:36
msgid ""
"The :manual:`cmake-file-api(7)` \"codemodel\" version 2 \"target\" object "
"gained a new ``interfaceSources`` array field, and the ``sourceGroups`` "
"array items gained a new ``interfaceSourceIndexes`` array field."
msgstr ""

#: ../../../release/4.3.rst:41
msgid "Platforms"
msgstr ""

#: ../../../release/4.3.rst:43
msgid ""
"``HIP`` language code may now be compiled for SPIR-V targets, e.g., via "
"chipStar.  See the :variable:`CMAKE_HIP_PLATFORM` variable."
msgstr ""

#: ../../../release/4.3.rst:47
msgid "Command-Line"
msgstr ""

#: ../../../release/4.3.rst:49
msgid ""
":option:`cmake --version` now supports a ``=json-v1`` value to print "
"detailed version information in a JSON format."
msgstr ""

#: ../../../release/4.3.rst:52
msgid ""
":option:`cmake --build` now supports specifying a build directory and preset "
"together.  The build preset will be used with the explicit build directory "
"substituted."
msgstr ""

#: ../../../release/4.3.rst:56
msgid ""
"The :option:`cmake -E` commands :option:`md5sum <cmake-E md5sum>`, :option:"
"`sha1sum <cmake-E sha1sum>`, :option:`sha224sum <cmake-E sha224sum>`, :"
"option:`sha256sum <cmake-E sha256sum>`, :option:`sha384sum <cmake-E "
"sha384sum>`, and :option:`sha512sum <cmake-E sha512sum>` now support reading "
"from standard input by passing ``-``."
msgstr ""

#: ../../../release/4.3.rst:65
msgid ""
"The :option:`cmake -E bin2c <cmake-E bin2c>` command-line tool was added."
msgstr ""

#: ../../../release/4.3.rst:67
msgid "The :option:`cmake -E tar <cmake-E tar>` command-line tool:"
msgstr ""

#: ../../../release/4.3.rst:69
msgid ""
"Gained a ``--cmake-tar-compression-level`` flag to specify the compression "
"level."
msgstr ""

#: ../../../release/4.3.rst:71
msgid ""
"Gained a ``--cmake-tar-compression-method`` flag to specify the compression "
"method."
msgstr ""

#: ../../../release/4.3.rst:73
msgid ""
"Gained a ``--cmake-tar-threads`` flag to enable multithreaded operations."
msgstr ""

#: ../../../release/4.3.rst:74
msgid ""
"Now supports specifying compression method and level for ``7zip`` and "
"``zip`` formats."
msgstr ""

#: ../../../release/4.3.rst:76
msgid "Gained a ``--format=raw`` flag to disable compression."
msgstr ""

#: ../../../release/4.3.rst:77
msgid "Gained a ``--lzma`` flag to specify ``LZMA`` compression."
msgstr ""

#: ../../../release/4.3.rst:80
msgid "Commands"
msgstr ""

#: ../../../release/4.3.rst:82
msgid ""
"The :command:`cmake_instrumentation` command was added to make project-level "
"instrumentation queries."
msgstr ""

#: ../../../release/4.3.rst:85
msgid "The :command:`file(ARCHIVE_CREATE)` command:"
msgstr ""

#: ../../../release/4.3.rst:87
msgid "Gained a ``THREADS`` option to enable multithreaded operations."
msgstr ""

#: ../../../release/4.3.rst:88
msgid ""
"Now supports ``COMPRESSION`` method ``Deflate`` as an alias for ``GZip``."
msgstr ""

#: ../../../release/4.3.rst:89
msgid "Now supports ``COMPRESSION`` method ``LZMA``."
msgstr ""

#: ../../../release/4.3.rst:90
msgid "Now supports ``COMPRESSION`` method ``LZMA2`` as an alias for ``XZ``."
msgstr ""

#: ../../../release/4.3.rst:91
msgid "Now supports ``COMPRESSION`` method ``PPMd`` for format ``7zip``."
msgstr ""

#: ../../../release/4.3.rst:92
msgid ""
"Now supports ``COMPRESSION`` and ``COMPRESSION_LEVEL`` options for formats "
"``7zip`` and ``zip``."
msgstr ""

#: ../../../release/4.3.rst:95
msgid ""
"The :command:`get_property` and :command:`set_property` commands now support "
"a ``FILE_SET`` scope for file set properties of a target."
msgstr ""

#: ../../../release/4.3.rst:98
msgid ""
"The :command:`install(PACKAGE_INFO)` and :command:`export(PACKAGE_INFO)` "
"commands now support specifying ``CXX_MODULES_DIRECTORY`` for exporting C+"
"+20 modules."
msgstr ""

#: ../../../release/4.3.rst:102
msgid ""
"The :command:`string(JSON)` command gained new ``GET_RAW`` and "
"``STRING_ENCODE`` modes."
msgstr ""

#: ../../../release/4.3.rst:105
msgid ""
"The :command:`source_group` command now supports :manual:`generator "
"expressions <cmake-generator-expressions(7)>`."
msgstr ""

#: ../../../release/4.3.rst:108
msgid ""
"The :command:`cmake_host_system_information` command gained a "
"``LOCALE_CHARSET`` query for the expected :manual:`cmake-language(7)` script "
"encoding."
msgstr ""

#: ../../../release/4.3.rst:113
msgid "Variables"
msgstr ""

#: ../../../release/4.3.rst:115
msgid ""
"The :variable:`CMAKE_<LANG>_LINK_FLAGS` and :variable:"
"`CMAKE_<LANG>_LINK_FLAGS_<CONFIG>` variables were added to support per-"
"language link flags for all target types. See policy :policy:`CMP0210`."
msgstr ""

#: ../../../release/4.3.rst:120
msgid ""
"The :variable:`CMAKE_CXX_MODULE_STD` variable and corresponding :prop_tgt:"
"`CXX_MODULE_STD` target property were added to control the availability of "
"``import std`` for C++ targets."
msgstr ""

#: ../../../release/4.3.rst:124
msgid ""
"The read-only :variable:`CMAKE_CXX_COMPILER_IMPORT_STD` variable was added "
"to list the C++ standard levels for which ``import std`` is available on the "
"current toolchain."
msgstr ""

#: ../../../release/4.3.rst:128
msgid ""
"The :variable:`CMAKE_CXX_STDLIB_MODULES_JSON` variable was added to specify "
"an ``import std`` module metadata file instead of relying on automatic "
"detection from the C++ compiler."
msgstr ""

#: ../../../release/4.3.rst:132
msgid ""
"The :variable:`CMAKE_VERIFY_PRIVATE_HEADER_SETS` variable and corresponding :"
"prop_tgt:`VERIFY_PRIVATE_HEADER_SETS` target property were added to enable "
"build rules that verify all headers in private file sets can be used on "
"their own."
msgstr ""

#: ../../../release/4.3.rst:138
msgid "Properties"
msgstr ""

#: ../../../release/4.3.rst:140
msgid ""
"A :prop_tgt:`<LANG>_PVS_STUDIO` target property and supporting :variable:"
"`CMAKE_<LANG>_PVS_STUDIO` variable were introduced to tell :ref:`Makefile "
"Generators` and :ref:`Ninja Generators` to run ``pvs-studio-analyzer`` with "
"the compiler for ``C`` and ``CXX`` languages."
msgstr ""

#: ../../../release/4.3.rst:145
msgid ""
"When :prop_tgt:`VERIFY_INTERFACE_HEADER_SETS` is set to true on an "
"executable target, that target's interface file sets are verified regardless "
"of its :prop_tgt:`ENABLE_EXPORTS` property. See policy :policy:`CMP0209`."
msgstr ""

#: ../../../release/4.3.rst:149
msgid ""
"The :prop_tgt:`PRIVATE_HEADER_SETS_TO_VERIFY` target property was added to "
"customize which private file sets to verify when the target's :prop_tgt:"
"`VERIFY_PRIVATE_HEADER_SETS` property is true."
msgstr ""

#: ../../../release/4.3.rst:154
msgid "Modules"
msgstr ""

#: ../../../release/4.3.rst:156
msgid ""
"The :module:`FindCUDAToolkit` module now creates a ``CUDA::bin2c`` imported "
"target for the :ref:`bin2c <FindCUDAToolkit_bin2c>` utility."
msgstr ""

#: ../../../release/4.3.rst:159
msgid ""
"The :module:`FindLibXml2` module gained a ``LibXml2_USE_STATIC_LIBS`` hint "
"to select static libraries."
msgstr ""

#: ../../../release/4.3.rst:162
msgid "The :module:`FindRuby` module now provides imported targets."
msgstr ""

#: ../../../release/4.3.rst:164
msgid ""
"The :module:`FindSQLite3` module now provides imported targets with the "
"``SQLite3::`` prefix."
msgstr ""

#: ../../../release/4.3.rst:167
msgid ""
"The :module:`UseJava` module's :command:`add_jar` command now accepts a new "
"``INCLUDE_MODULES`` option that adds its arguments to the ``--module-path`` "
"argument to the Java compiler. This allows building JAR files that use JPMS "
"modules in their build."
msgstr ""

#: ../../../release/4.3.rst:173
msgid "Generator Expressions"
msgstr ""

#: ../../../release/4.3.rst:175
msgid ""
":ref:`String Comparison <String Comparisons Generator Expressions>` "
"generator expressions were added."
msgstr ""

#: ../../../release/4.3.rst:178
msgid ""
":genex:`$<STRING:...>` generator expressions were added for :ref:`query "
"<String Queries Generator Expressions>`, :ref:`generation <String Generating "
"Generator Expressions>`, and :ref:`transformation <String Transforming "
"Generator Expressions>` operations on strings."
msgstr ""

#: ../../../release/4.3.rst:184
msgid ""
"The :genex:`$<FILE_SET_EXISTS>` and :genex:`$<FILE_SET_PROPERTY>` generator "
"expressions were added to query file set existence and properties."
msgstr ""

#: ../../../release/4.3.rst:187
msgid ""
"The :genex:`$<SOURCE_EXISTS>` and :genex:`$<SOURCE_PROPERTY>` generator "
"expressions were added to query source file existence and properties."
msgstr ""

#: ../../../release/4.3.rst:191
msgid "CTest"
msgstr ""

#: ../../../release/4.3.rst:193
msgid "The :module:`CTestCoverageCollectGCOV` module:"
msgstr ""

#: ../../../release/4.3.rst:195
msgid "Now supports ``TARBALL_COMPRESSION`` method ``LZMA``."
msgstr ""

#: ../../../release/4.3.rst:197
msgid ""
"Now supports ``TARBALL_COMPRESSION`` method ``LZMA2`` as an alias for ``XZ``."
msgstr ""

#: ../../../release/4.3.rst:200
msgid ""
"Now supports ``FROM_EXT`` with file extensions corresponding to ``LZMA`` and "
"``ZSTD`` compression."
msgstr ""

#: ../../../release/4.3.rst:204
msgid "CPack"
msgstr ""

#: ../../../release/4.3.rst:206
msgid ""
":module:`CPack` gained the :variable:`CPACK_COMPRESSION_LEVEL` variable to "
"control the compression level used when creating packages."
msgstr ""

#: ../../../release/4.3.rst:210
msgid "The :cpack_gen:`CPack Archive Generator`:"
msgstr ""

#: ../../../release/4.3.rst:212
msgid ""
"Now supports compression method specification for formats ``7zip`` and "
"``zip``."
msgstr ""

#: ../../../release/4.3.rst:215
msgid ""
"Gained a :variable:`CPACK_ARCHIVE_COMPRESSION_LEVEL` option to control the "
"compression level used when creating archive packages."
msgstr ""

#: ../../../release/4.3.rst:218
msgid ""
"Gained :variable:`CPACK_ARCHIVE_UID` and :variable:`CPACK_ARCHIVE_GID` "
"options to specify the UID and GID of archive entries, respectively. The "
"defaults are UID ``0`` and GID ``0``.  See policy :policy:`CMP0206`."
msgstr ""

#: ../../../release/4.3.rst:222
msgid ""
"The :cpack_gen:`CPack DEB Generator` gained a new :variable:"
"`CPACK_DEBIAN_COMPRESSION_LEVEL` variable to control the compression level "
"used when creating Debian packages."
msgstr ""

#: ../../../release/4.3.rst:226
msgid ""
"The :cpack_gen:`CPack WIX Generator` now supports per-user installers by "
"setting :variable:`CPACK_WIX_INSTALL_SCOPE` to ``perUser``."
msgstr ""

#: ../../../release/4.3.rst:230
msgid "Deprecated and Removed Features"
msgstr ""

#: ../../../release/4.3.rst:232
msgid ""
"The :variable:`CMAKE_ENABLE_EXPORTS` variable is deprecated in favor of the :"
"variable:`CMAKE_EXECUTABLE_ENABLE_EXPORTS` and :variable:"
"`CMAKE_SHARED_LIBRARY_ENABLE_EXPORTS` variables."
msgstr ""

#: ../../../release/4.3.rst:236
msgid ""
"The :command:`export(EXPORT)` command no longer allows certain arguments to "
"be missing or empty.  See policy :policy:`CMP0208`."
msgstr ""

#: ../../../release/4.3.rst:240
msgid "Other Changes"
msgstr ""

#: ../../../release/4.3.rst:242
msgid ""
"The :option:`cmake -E tar <cmake-E tar>` command-line tool and the :command:"
"`file(ARCHIVE_EXTRACT)` command now reject archive entries whose paths are "
"absolute or contain ``..`` path traversal components."
msgstr ""

#: ../../../release/4.3.rst:247
msgid ""
"The family of :option:`cmake --trace` and related commands now print \"end\" "
"commands for control structures: :command:`endblock`, :command:"
"`endforeach`, :command:`endfunction`, :command:`endif`, :command:`endmacro`, "
"and :command:`endwhile`."
msgstr ""

#: ../../../release/4.3.rst:252
msgid ""
"The :command:`file(CREATE_LINK)` command's ``COPY_ON_ERROR`` option, when "
"used with a directory, now copies directory content. See policy :policy:"
"`CMP0205`."
msgstr ""

#: ../../../release/4.3.rst:256
msgid ""
"The :command:`file(GET_RUNTIME_DEPENDENCIES)` and :command:"
"`install(RUNTIME_DEPENDENCY_SET)` commands now normalize paths before "
"matching filters.  See policy :policy:`CMP0207`."
msgstr ""

#: ../../../release/4.3.rst:260
msgid ""
"The precompiled Linux ``aarch64`` binaries provided on `cmake.org <https://"
"cmake.org/download/>`_ now require GLIBC 2.28 or higher."
msgstr ""

#: ../../../release/4.3.rst:263
msgid ""
"The precompiled macOS binary provided on ``cmake.org`` for macOS 10.13+ now "
"requires macOS 12 or newer for the :manual:`cmake-gui(1)` application. The "
"command-line tools still run on macOS 10.13."
msgstr ""

#: ../../../release/4.3.rst:267
msgid ""
"The precompiled Windows binaries provided on `cmake.org <https://cmake.org/"
"download/>`_ now require Windows 10 or higher."
msgstr ""
